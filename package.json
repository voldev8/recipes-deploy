{
  "name": "flavorites",
  "version": "1.0.0",
  "description": "Contact manager app",
  "main": "app.js",
  "private": true,
  "scripts": {
    "start": "node ./bin/www",
    "server": "nodemon ./bin/www",
    "client": "npm start --prefix client",
    "clientinstall": "npm install --prefix client",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "heroku-postbuild": "NPM_CONFIG_PRODUCTION=false npm install --prefix client && npm run build --prefix client"
  },
  "keywords": [
    "recipes",
    "flavors",
    "cooking",
    "favorites",
    "food",
    "meal"
  ],
  "author": "Volkan Uyarer",
  "license": "MIT",
  "dependencies": {
    "@sendgrid/mail": "^7.2.2",
    "bcryptjs": "^2.4.3",
    "concurrently": "^5.3.0",
    "config": "^3.3.1",
    "cookie-parser": "~1.4.4",
    "debug": "~2.6.9",
    "dotenv": "^8.2.0",
    "express": "~4.16.1",
    "express-validator": "^6.6.1",
    "helmet": "^4.1.0",
    "html-to-text": "^5.1.1",
    "http-errors": "~1.6.3",
    "jsonwebtoken": "^8.5.1",
    "mongoose": "^5.9.19",
    "morgan": "~1.9.1",
    "nodemailer": "^6.4.11",
    "pug": "^3.0.0",
    "slugify": "^1.4.0"
  }
}
